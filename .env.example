# AI 剧本创作工具 — 配置文件
# 复制此文件为 .env 并填入你的配置

# === 必选：AI 后端（三选一，取消注释即可）===

# 方案 A：Claude API（推荐）
# SCRIPT_TOOL_AI_PROVIDER=claude
# SCRIPT_TOOL_AI_MODEL=claude-sonnet-4-6
# SCRIPT_TOOL_ANTHROPIC_API_KEY=sk-ant-你的key

# 方案 B：LM Studio（免费本地）
# SCRIPT_TOOL_AI_PROVIDER=local
# SCRIPT_TOOL_AI_MODEL=qwen2.5-7b-instruct
# (端口 1234 已预设，无需改)

# 方案 C：OpenAI GPT / DeepSeek 等兼容 API
SCRIPT_TOOL_AI_PROVIDER=openai
SCRIPT_TOOL_AI_MODEL=deepseek-v4-flash
SCRIPT_TOOL_OPENAI_API_KEY=sk-3f5f788162a74c12a21f095981a53004
# 若使用 DeepSeek 等第三方 API，取消 base_url 注释
SCRIPT_TOOL_OPENAI_BASE_URL=https://api.deepseek.com

# === 可选：数据库路径（Windows/WSL 用户建议设置）===
# SCRIPT_TOOL_DATABASE_URL=sqlite:///C:/Users/你的用户名/script_tool.db
