# AI 剧本创作工具 — 配置文件
# 复制此文件为 .env 并填入你的配置

# ═══════════════════════════════════════════════════════════════
# 流水线 AI 后端（用于剧本生成流水线，选一个）
# ═══════════════════════════════════════════════════════════════

# 方案 A：Claude API（推荐，中文理解最强）
SCRIPT_TOOL_AI_PROVIDER=claude
SCRIPT_TOOL_AI_MODEL=claude-sonnet-4-6
# SCRIPT_TOOL_ANTHROPIC_API_KEY=sk-ant-你的key

# 方案 B：OpenAI GPT
# SCRIPT_TOOL_AI_PROVIDER=openai
# SCRIPT_TOOL_AI_MODEL=gpt-4o
# SCRIPT_TOOL_OPENAI_API_KEY=sk-你的key

# 方案 C：DeepSeek（推荐性价比，中文优秀）
# SCRIPT_TOOL_AI_PROVIDER=deepseek
# SCRIPT_TOOL_AI_MODEL=deepseek-chat
# SCRIPT_TOOL_DEEPSEEK_API_KEY=sk-你的key

# 方案 D：Gemini（Google，免费额度友好）
# SCRIPT_TOOL_AI_PROVIDER=gemini
# SCRIPT_TOOL_AI_MODEL=gemini-2.5-flash
# SCRIPT_TOOL_GEMINI_API_KEY=你的key

# 方案 E：LM Studio / Ollama（免费本地运行）
# SCRIPT_TOOL_AI_PROVIDER=local
# SCRIPT_TOOL_AI_MODEL=qwen2.5-7b-instruct
# (端口 1234 已预设)

# ═══════════════════════════════════════════════════════════════
# AI 助手聊天配置（项目页面右下角 AI 助手）
# ═══════════════════════════════════════════════════════════════
#
# AI 助手支持 5 种模型，在页面下拉菜单中切换。
# 你需要为你想用的模型配置对应的 API Key：

# Claude：
# SCRIPT_TOOL_ANTHROPIC_API_KEY=sk-ant-你的key

# GPT (OpenAI)：
# SCRIPT_TOOL_OPENAI_API_KEY=sk-你的key
# 可选：自定义 API 地址（如使用中转服务）
# SCRIPT_TOOL_OPENAI_BASE_URL=https://你的代理地址/v1

# DeepSeek：
# SCRIPT_TOOL_DEEPSEEK_API_KEY=sk-你的key
# SCRIPT_TOOL_DEEPSEEK_MODEL=deepseek-chat    # 可选，默认 deepseek-chat

# Gemini (Google)：
# SCRIPT_TOOL_GEMINI_API_KEY=你的key
# SCRIPT_TOOL_GEMINI_MODEL=gemini-2.5-flash   # 可选，默认 gemini-2.5-flash

# 本地模型（LM Studio / Ollama）：
# SCRIPT_TOOL_LOCAL_LLM_URL=http://localhost:1234/v1
# SCRIPT_TOOL_LOCAL_LLM_API_KEY=not-needed

# ═══════════════════════════════════════════════════════════════
# 其他可选配置
# ═══════════════════════════════════════════════════════════════

# 数据库路径（Windows / WSL 用户建议设置）
# SCRIPT_TOOL_DATABASE_URL=sqlite:///C:/Users/你的用户名/script_tool.db
